---
import ContactForm from './ContactForm.astro';
---

<section id="contact" aria-labelledby="cta-heading" class="py-20 md:py-32 bg-primary text-white">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h2 id="cta-heading" class="text-3xl md:text-4xl font-bold mb-6">Ready to Transform Your Business?</h2>
    <p class="text-lg md:text-xl mb-10 max-w-2xl mx-auto font-light text-text-light">
      Let's connect and discuss how Wijnbladhs Consulting can help you achieve your goals.
    </p>

    <div class="max-w-4xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-12 items-start mt-12">
      <div class="lg:text-left flex flex-col justify-center h-full">
        <h3 class="text-2xl font-semibold mb-4">Reach out directly</h3>
        <p class="mb-8 opacity-90 text-text-light">
          Whether you have a specific project in mind or just want to explore how we can assist your business, we'd love to hear from you.
        </p>
        <div class="mt-auto flex flex-col items-start gap-4">
          <a
            href="mailto:info@wijnbladhs.com"
            class="inline-block bg-accent hover:bg-yellow-600 text-white font-semibold py-4 px-8 rounded-md transition duration-300 shadow-lg text-lg focus:ring-2 focus:ring-offset-2 focus:ring-offset-primary focus:ring-accent focus:outline-none"
          >
            Email Us: info@wijnbladhs.com
          </a>
          <a
            href="/book"
            class="inline-flex items-center text-accent hover:text-white font-medium transition duration-300 focus:ring-2 focus:ring-accent focus:outline-none rounded px-2 py-1 -ml-2"
          >
            Or book a meeting directly &rarr;
          </a>
        </div>
      </div>

      <div class="bg-bg-light rounded-lg shadow-xl p-1 w-full text-text-dark">
        <ContactForm />
      </div>
    </div>
  </div>
</section>
