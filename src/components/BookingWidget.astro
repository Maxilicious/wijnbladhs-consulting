---
// src/components/BookingWidget.astro
const bookingDays = import.meta.env.BOOKING_DAYS || '1,2,3,4,5';
const bookingMaxDays = import.meta.env.BOOKING_MAX_DAYS_AHEAD || '30';
---

<div class="booking-widget-container max-w-md w-full mx-auto bg-white rounded-lg shadow-md p-6" data-booking-widget data-booking-days={bookingDays} data-booking-max-days={bookingMaxDays}>

  <div class="flex flex-col gap-6">

    <!-- Calendar Section -->
    <div>
      <div class="flex justify-between items-center mb-4">
        <button type="button" class="prev-month text-text-dark hover:text-primary focus:outline-none focus:ring-2 focus:ring-accent rounded-full p-1 transition-colors" aria-label="Previous Month">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
        </button>
        <h2 class="month-display text-lg font-semibold text-primary"></h2>
        <button type="button" class="next-month text-text-dark hover:text-primary focus:outline-none focus:ring-2 focus:ring-accent rounded-full p-1 transition-colors" aria-label="Next Month">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
        </button>
      </div>

      <div class="calendar-grid grid grid-cols-7 gap-1 text-center text-sm">
        <!-- Calendar days injected by JS -->
      </div>
    </div>

    <!-- Slots Section -->
    <div class="slots-container hidden">
      <h3 class="text-md font-semibold text-text-dark mb-3">Available Times (<span class="selected-date-display text-primary"></span>)</h3>
      <div class="slots-list grid grid-cols-3 gap-2 content-start max-h-48 overflow-y-auto pr-1">
        <!-- Time slots injected by JS -->
      </div>
    </div>

  </div>

  <!-- Booking Form -->
  <div class="booking-form-container hidden mt-6 pt-6 border-t border-gray-200">
    <h3 class="text-lg font-semibold text-primary mb-4">Book <span class="selected-time-display"></span> on <span class="selected-date-display text-sm font-normal text-text-dark"></span></h3>

    <form class="booking-form flex flex-col gap-4 text-left font-sans text-sm">
      <input type="hidden" name="date" />
      <input type="hidden" name="time" />
      <input type="hidden" name="duration" value="30" />

      <div>
        <label for="widget-name" class="block text-text-dark font-medium mb-1">Name</label>
        <input
          type="text"
          id="widget-name"
          name="name"
          placeholder="Name"
          required
          class="w-full px-3 py-2 border border-gray-300 rounded-md text-text-dark focus:outline-none focus:ring-2 focus:ring-accent focus:border-transparent transition-colors"
        />
      </div>

      <div>
        <label for="widget-email" class="block text-text-dark font-medium mb-1">Email</label>
        <input
          type="email"
          id="widget-email"
          name="email"
          placeholder="Email"
          required
          class="w-full px-3 py-2 border border-gray-300 rounded-md text-text-dark focus:outline-none focus:ring-2 focus:ring-accent focus:border-transparent transition-colors"
        />
      </div>

      <div>
        <label for="widget-topic" class="block text-text-dark font-medium mb-1">Topic</label>
        <textarea
          id="widget-topic"
          name="topic"
          rows="2"
          placeholder="Topic"
          required
          class="w-full px-3 py-2 border border-gray-300 rounded-md text-text-dark focus:outline-none focus:ring-2 focus:ring-accent focus:border-transparent transition-colors resize-none"
        ></textarea>
      </div>

      <button
        type="submit"
        class="w-full bg-primary hover:bg-blue-800 text-white font-semibold py-2 px-4 rounded-md transition duration-300 shadow-sm focus:ring-2 focus:ring-offset-2 focus:ring-offset-white focus:ring-primary focus:outline-none mt-2"
      >
        Confirm
      </button>
    </form>
  </div>

  <!-- Status Message -->
  <div class="status-message hidden mt-4 p-3 rounded-md text-sm" aria-live="polite"></div>

</div>

<script>
  import '../scripts/booking.js';
</script>
