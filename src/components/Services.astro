---
const services = [
  {
    title: "Strategy Consulting",
    description: "Aligning your business objectives with actionable plans for sustainable growth and competitive advantage."
  },
  {
    title: "Operational Efficiency",
    description: "Streamlining processes to reduce costs, improve quality, and enhance overall organizational performance."
  },
  {
    title: "Advisory Services",
    description: "Providing expert guidance to executive teams on critical decisions and change management initiatives."
  }
];
---

<section id="services" class="py-20 bg-gray-50">
  <div class="container mx-auto px-4">
    <div class="text-center mb-16">
      <h2 class="text-4xl font-bold text-primary mb-4">Our Services</h2>
      <div class="w-24 h-1 bg-accent mx-auto"></div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
      {services.map(service => (
        <div class="bg-white p-8 rounded-lg shadow-md hover:shadow-lg transition duration-300 border border-gray-100">
          <h3 class="text-2xl font-semibold mb-4 text-primary">{service.title}</h3>
          <p class="text-gray-600 leading-relaxed">{service.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
